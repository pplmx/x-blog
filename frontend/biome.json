{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "ignoreUnknown": true,
    "experimentalScannerIgnores": [".next/**", "node_modules/**", "dist/**", "coverage/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noImplicitAnyLet": "off"
      },
      "correctness": {
        "useParseIntRadix": "off",
        "noUnusedImports": "off"
      },
      "style": {
        "useImportType": "off"
      },
      "a11y": {
        "noLabelWithoutControl": "off",
        "useButtonType": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  }
}