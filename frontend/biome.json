{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": ["app/**", "components/**", "lib/**", "types/**", "mocks/**", "*.ts", "*.tsx", "*.json"]
  },
  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": { "actions": { "source": { "organizeImports": "off" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noImplicitAnyLet": "off"
      },
      "correctness": {
        "useParseIntRadix": "off",
        "noUnusedImports": "off",
        "noUnusedVariables": "off"
      },
      "style": {
        "useImportType": "off",
        "useNodejsImportProtocol": "off"
      },
      "a11y": {
        "noLabelWithoutControl": "off",
        "useButtonType": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "performance": {
        "noImgElement": "off"
      },
      "complexity": {
        "useLiteralKeys": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  }
}
